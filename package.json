{
  "name": "srp6-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @trinity-flux/srp6, a TrinityCore-compatible SRP6 verifier library",
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev": "turbo run dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build test --filter @trinity-flux/srp6 && changeset publish",
    "start:sample": "pnpm --filter @trinity-flux/sample start",
    "start:sampledb": "pnpm --filter @trinity-flux/sample start:db"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@changesets/cli": "^2.31.0",
    "turbo": "^2.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
